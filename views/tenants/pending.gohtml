<div style="display: flex; align-items: center; justify-content: center; height: 60vh; text-align: center;">
    <div style="max-width: 400px; padding: 2rem; border-radius: 12px; background: #fff; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);">
        <span style="font-size: 3rem; margin-bottom: 1rem; display: block;">👋</span>
        <h1 style="font-size: 1.5rem; margin-bottom: 1rem;">Welcome to {{.Name}}!</h1>
        <p style="color: #666; line-height: 1.5;">Your account is currently pending activation. Our team is reviewing your setup and will have it ready for you shortly.</p>
        <p style="color: #666; line-height: 1.5;">Please check back later.</p>
    </div>
</div>
